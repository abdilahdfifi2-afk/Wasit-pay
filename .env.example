# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lovable Cloud Auth (if using)
VITE_LOVABLE_AUTH_URL=https://auth.lovable.dev

# API Configuration
VITE_API_BASE_URL=https://wasit-pay.com/api

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true

# Cloudflare Environment Variables (for production)
# These are set in Cloudflare Pages environment settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Stripe or Payment Gateway
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...

# Optional: Email Service
# SENDGRID_API_KEY=SG.xxxxx

# Optional: Analytics
# POSTHOG_API_KEY=phc_xxxxx
